# Bootloader hwdef for Flywoo GOKU F722 PRO MINI V2
#
# Produces the ArduPilot bootloader that:
#   - exposes a USB DFU-compatible upload interface
#   - accepts firmware from Mission Planner / uploader.py
#   - jumps to the application after a short wait
#
# Flash layout (STM32F722RET6, 512 KB):
#   0x08000000  sectors 0-1  32 KB  bootloader   (FLASH_BOOTLOADER_LOAD_KB)
#   0x08008000  sectors 2-3  32 KB  EEPROM/params
#   0x08010000  sectors 4-7 384 KB  application

# -----------------------------------------------------------------------
# MCU — F722 silicon uses ArduPilot's STM32F732xx module
# -----------------------------------------------------------------------
MCU STM32F7xx STM32F732xx

APJ_BOARD_ID AP_HW_FLYWOOF722PROMINI_V2

OSCILLATOR_HZ 8000000
FLASH_SIZE_KB 512

# Bootloader sits at the start of flash; the app is loaded at +32 KB
FLASH_RESERVE_START_KB 0
FLASH_BOOTLOADER_LOAD_KB 32

# USB strings shown in DFU / Mission Planner device list
USB_STRING_MANUFACTURER "Flywoo"
USB_STRING_PRODUCT "GOKU-F722-Pro-Mini-V2-BL"

# -----------------------------------------------------------------------
# USB — required for DFU firmware upload
# -----------------------------------------------------------------------
PA11 OTG_FS_DM OTG1
PA12 OTG_FS_DP OTG1

# -----------------------------------------------------------------------
# UART1 — also supports firmware upload via serial
# -----------------------------------------------------------------------
PA9  USART1_TX USART1
PA10 USART1_RX USART1

SERIAL_ORDER OTG1 USART1

# -----------------------------------------------------------------------
# Status LED — PC15 active-low; blinks while the bootloader waits
# -----------------------------------------------------------------------
PC15 LED_BOOTLOADER OUTPUT LOW
define HAL_LED_ON 0

# -----------------------------------------------------------------------
# Bootloader keeps storage empty (params live in the application region)
# -----------------------------------------------------------------------
define HAL_USE_EMPTY_STORAGE 1
define HAL_STORAGE_SIZE 16384
